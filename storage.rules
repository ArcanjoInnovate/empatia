rules_version = '2';

// Regras de produГѓВ§ГѓВЈo do Firebase Storage para o app Empatia.
//
// Tudo que o app envia (fotos de perfil, de filhos, de sonhos e de
// doaГѓВ§ГѓВµes) cai em uploads/{fileName} Гўв‚¬вЂќ ver StorageRepository no app.
//
// Regra geral:
//   - Leitura: pГѓВєblica (as imagens aparecem em telas de outros
//     usuГѓВЎrios Гўв‚¬вЂќ perfil pГѓВєblico, feed de sonhos, vitrine de doaГѓВ§ГѓВµes).
//   - Escrita: sГѓВі para usuГѓВЎrios autenticados, com limite de 5MB e
//     restrito a tipos de imagem (mesma validaГѓВ§ГѓВЈo jГѓВЎ feita no
//     StorageService do app Гўв‚¬вЂќ aqui ГѓВ© a camada de seguranГѓВ§a real).
service firebase.storage {
  match /b/{bucket}/o {

    match /uploads/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null;
    }

    // Bloqueia qualquer outro caminho nГѓВЈo previsto explicitamente acima.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
